{
  "name": "@analytiq/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build":   "tsc",
    "start":   "node dist/server.js",
    "db:migrate": "cd apps/api && npx tsx src/db/migrate.ts",
    "db:seed":    "cd apps/api && npx tsx src/db/seed.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed":    "tsx src/db/seed.ts"
  },  
  "dependencies": {
    "@analytiq/shared": "*",
    "@sentry/node":     "^8.28.0",
    "fastify":          "^4.28.1",
    "@fastify/cors":    "^9.0.1",
    "@fastify/jwt":     "^8.0.1",
    "@fastify/swagger":  "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@supabase/supabase-js": "^2.45.4",
    "postgres":         "^3.4.4",
    "zod":              "^3.23.8",
    "pino":             "^9.4.0",
    "pino-pretty":      "^11.2.2",
    "node-cron":        "^3.0.3",
    "dotenv":           "^16.4.5"
  },
  "devDependencies": {
    "@types/node":      "^22.5.4",
    "@types/node-cron": "^3.0.11",
    "typescript":       "^5.5.3",
    "tsx":              "^4.19.0"
  }
}
