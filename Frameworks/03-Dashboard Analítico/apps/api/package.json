{
  "name": "@analytiq/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "cd apps/api && npx tsx src/db/migrate.ts",
    "db:seed": "cd apps/api && npx tsx src/db/seed.ts",
